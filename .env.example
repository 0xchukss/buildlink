# Frontend
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
NEXT_PUBLIC_ESCROW_ADDRESS=0xYourCircleEscrowWalletAddress

# Circle Admin Wallet (Backend)
CIRCLE_API_KEY=your_circle_api_key
CIRCLE_ENTITY_SECRET=your_circle_entity_secret
ESCROW_WALLET_ADDRESS=0xYourCircleEscrowWalletAddress

# Optional NFT proof minting (leave disabled for payout-only flow)
ENABLE_PROOF_NFT=false
# ERC-721 proof contract deployed from template 76b83278-50e2-4006-8b63-5b1a2a814533
PROOF_NFT_CONTRACT_ADDRESS=

# Optional: override if Circle changes the monitor endpoint
CIRCLE_MONITOR_API_URL=https://api.circle.com/v1/w3s/monitor/events

# Persistent storage
DATABASE_URL=file:./prisma/dev.db

# Object storage: set STORAGE_PROVIDER=s3 for S3/R2/MinIO
STORAGE_PROVIDER=local
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SIGNED_URL_TTL_SECONDS=900
